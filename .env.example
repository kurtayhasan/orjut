# Orjut — örnek ortam değişkenleri (gerçek secret koyma; .env.local kullan)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini (server-side only)
GEMINI_API_KEY=your_gemini_api_key

# AgroMonitoring (opsiyonel; client'ta kullanılıyorsa güvenlik gözden geçirilmeli)
NEXT_PUBLIC_AGRO_API_KEY=

# Varsayılan harita merkezi (fallback)
NEXT_PUBLIC_DEFAULT_LAT=37.7478
NEXT_PUBLIC_DEFAULT_LON=27.3971

# Web Push (opsiyonel)
NEXT_PUBLIC_VAPID_KEY=

# Cron koruması (Vercel /api/cron/*)
CRON_SECRET=your_cron_secret
